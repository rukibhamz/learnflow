<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /learnflow/

    # Redirect trailing slashes (only for non-directory URIs)
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ %1 [L,R=301]

    # Forward everything except real files to index.php
    # (directories are NOT excluded — prevents exposing internal folders)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
