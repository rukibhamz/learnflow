APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# ASSET_URL=  # Optional. Set to APP_URL if app is in a subdirectory (e.g. /learnflow)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,slack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
LOG_SLACK_LEVEL=error

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_CONNECTION=sessions
SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=database

CACHE_STORE=file
CACHE_DRIVER=file
CACHE_PREFIX=learnflow_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
REDIS_QUEUE_CONNECTION=queues
REDIS_QUEUE_RETRY_AFTER=360

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Production recommendations (set these when deploying)
# APP_ENV=production
# APP_DEBUG=false
# SESSION_SECURE_COOKIE=true
# SESSION_DRIVER=redis
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis

# Laravel Scout / Meilisearch
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# Google OAuth (Laravel Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback  # Optional, defaults to APP_URL/auth/google/callback

# GitHub OAuth (Laravel Socialite)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=${APP_URL}/auth/github/callback  # Optional, defaults to APP_URL/auth/github/callback

# Content Protection (disable in local dev if needed)
CONTENT_PROTECTION_ENABLED=true

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
VAPID_SUBJECT=mailto:admin@learnflow.test
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
